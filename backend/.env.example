# Backend environment template.
# Primary FastAPI runtime env lives at backend/api/.env.
# This file mirrors the most important local-development values.

PROJECT_NAME=AirWise API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

POSTGRES_URI=postgresql+psycopg2://airwise:airwise123@localhost:5432/airwise
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=dev-influx-token
INFLUX_ORG=airwise
INFLUX_BUCKET=airwise_timeseries
LIVE_AQI_PROVIDER=cpcb
LIVE_AQI_BASE_URL=https://api.data.gov.in/resource/placeholder-cpcb-aqi
LIVE_AQI_API_KEY=
LIVE_AQI_TIMEOUT=20
LIVE_AQI_DEFAULT_LIMIT=1000

ALLOW_MOCK_AUTH=true
SOURCE_MOCK_MODE=true
FCM_ENABLED=false
FCM_DRY_RUN=true
DEFAULT_TRAIN_CITY=Delhi
TRAIN_TARGET_COLUMN=aqi
LOOKBACK_HOURS=24
FORECAST_HORIZONS=4,6,12,24
