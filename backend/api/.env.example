PROJECT_NAME=AirWise API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

POSTGRES_URI=postgresql+psycopg2://airwise:airwise123@localhost:5432/airwise
POSTGRES_ECHO=false

INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=dev-influx-token
INFLUX_ORG=airwise
INFLUX_BUCKET=airwise_timeseries
INFLUX_RAW_MEASUREMENT=aqi_raw
INFLUX_PROCESSED_MEASUREMENT=aqi_processed
INFLUX_PREDICTIONS_MEASUREMENT=aqi_predictions
INFLUX_MODEL_METRICS_MEASUREMENT=model_metrics
INFLUX_POLLUTANT_MEASUREMENT=pollutant_raw

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
ALLOW_MOCK_AUTH=true

FCM_ENABLED=false
FCM_DRY_RUN=true

DEFAULT_COUNTRY=India
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_THRESHOLD_AQI=150

SOURCE_MOCK_MODE=true
CPCB_BASE_URL=https://api.example.cpcb.gov.in
CPCB_TIMEOUT_SECONDS=20
CPCB_DEFAULT_LIMIT=500
LIVE_AQI_PROVIDER=cpcb
LIVE_AQI_BASE_URL=https://api.data.gov.in/resource/placeholder-cpcb-aqi
LIVE_AQI_API_KEY=
LIVE_AQI_TIMEOUT=20
LIVE_AQI_DEFAULT_LIMIT=1000

OPENAQ_BASE_URL=https://api.openaq.org/v3
OPENAQ_TIMEOUT_SECONDS=25
OPENAQ_DEFAULT_LIMIT=1000

WEATHER_BASE_URL=https://weather.example.com
WEATHER_TIMEOUT_SECONDS=10

PROCESSING_RESAMPLE_FREQUENCY=1h
PROCESSING_DEFAULT_LOOKBACK_HOURS=336
PROCESSING_SHORT_GAP_LIMIT_HOURS=2
PROCESSING_ENABLE_OUTLIER_CLIPPING=true
PROCESSING_AQI_CLIP_UPPER=500
PROCESSING_MISSING_STRATEGY=ffill_then_interp
PROCESSING_LONG_GAP_KEEP_MISSING=true

DATASET_TRAIN_RATIO=0.7
DATASET_VAL_RATIO=0.15
DATASET_TEST_RATIO=0.15
DEFAULT_TRAIN_CITY=Delhi
TRAIN_TARGET_COLUMN=aqi
LOOKBACK_HOURS=24
FORECAST_HORIZONS=4,6,12,24
