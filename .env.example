# ==================================================
# AirWise root environment template
# Copy to .env at repo root for docker-compose usage.
# ==================================================

# Core app
PROJECT_NAME=AirWise
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Demo + fallback mode
ALLOW_MOCK_AUTH=false
SOURCE_MOCK_MODE=false

# API URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Postgres
POSTGRES_DB=airwise
POSTGRES_USER=airwise
POSTGRES_PASSWORD=airwise123
POSTGRES_PORT=5432
POSTGRES_URI=postgresql+psycopg2://airwise:airwise123@localhost:5432/airwise

# InfluxDB
INFLUXDB_PORT=8086
INFLUXDB_INIT_MODE=setup
INFLUXDB_INIT_USERNAME=airwise
INFLUXDB_INIT_PASSWORD=airwise123
INFLUXDB_INIT_ORG=airwise
INFLUXDB_INIT_BUCKET=airwise_timeseries
INFLUXDB_INIT_ADMIN_TOKEN=dev-influx-token
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=dev-influx-token
INFLUX_ORG=airwise
INFLUX_BUCKET=airwise_timeseries
LIVE_AQI_PROVIDER=cpcb
LIVE_AQI_BASE_URL=https://api.data.gov.in/resource/placeholder-cpcb-aqi
LIVE_AQI_API_KEY=
LIVE_AQI_TIMEOUT=20
LIVE_AQI_DEFAULT_LIMIT=1000
DEFAULT_TRAIN_CITY=Delhi
TRAIN_TARGET_COLUMN=aqi
LOOKBACK_HOURS=24
FORECAST_HORIZONS=4,6,12,24

# Firebase / notifications (optional for local demo)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FCM_ENABLED=false
FCM_DRY_RUN=true
FCM_SERVER_KEY=
